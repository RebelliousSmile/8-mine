; 6 hotspots EXAMINE — worldbuilding, aucun flag, aucun EV.
; Hotspot Frank et Sofia désactivés pour dialogue dans cette scène
; (apparaîtront actifs en PRO-02 quand flag_emma_a_reveele sera lu).

[node name="ExamineDomes" parent="Hotspots" instance=ExtResource("3_hot")]
position = Vector2(960, 80)
hotspot_type = 2
libelle = "Dômes caméras au plafond"
examine_text = "Dix-sept. J'en ai compté dix-sept depuis l'entrée. Angles croisés. Pas d'angle mort visible de là où je suis."
interaction_offset = Vector2(0, 600)

[node name="CollisionShape2D" parent="Hotspots/ExamineDomes" index="0"]
shape = SubResource("RectangleShape2D_domes")

[node name="ExamineTraces" parent="Hotspots" instance=ExtResource("3_hot")]
position = Vector2(960, 940)
hotspot_type = 2
libelle = "Traces d'usure au sol"
examine_text = "Le mobilier est censé être modulable. Le sol dit le contraire — chacun a sa place depuis longtemps. Les habitudes se creusent vite dans un laboratoire."

[node name="CollisionShape2D" parent="Hotspots/ExamineTraces" index="0"]
shape = SubResource("RectangleShape2D_traces")

[node name="ExamineDrones" parent="Hotspots" instance=ExtResource("3_hot")]
position = Vector2(1780, 920)
hotspot_type = 2
libelle = "Drones sur socles"
examine_text = "En veille. Deux. Pour l'instant."
interaction_offset = Vector2(-100, 0)

[node name="CollisionShape2D" parent="Hotspots/ExamineDrones" index="0"]
shape = SubResource("RectangleShape2D_drones")

[node name="ExamineBaies" parent="Hotspots" instance=ExtResource("3_hot")]
position = Vector2(960, 380)
hotspot_type = 2
libelle = "Baies vitrées — vue Sous-Paris"
examine_text = "D'ici on voit les trois couches en même temps. Sous-Paris est une tache sombre tout en bas. De là-haut, ça disparaît presque."
interaction_offset = Vector2(0, 400)

[node name="CollisionShape2D" parent="Hotspots/ExamineBaies" index="0"]
shape = SubResource("RectangleShape2D_baies")

; EXAMINE sur les PNJ — observation passive (les NPC eux-mêmes sont
; cliquables mais sans dialogue ici, voir Frank/Sofia ci-dessus).
[node name="ExamineFrank" parent="Hotspots" instance=ExtResource("3_hot")]
position = Vector2(420, 780)
hotspot_type = 2
libelle = "Observer Frank"
examine_text = "Il me fixe depuis que les portes se sont ouvertes. Il n'a pas bougé. Il n'a pas cillé. {emma_prenom} n'a pas dit son prénom. Elle a dit Stratom."
interaction_offset = Vector2(80, 50)

[node name="CollisionShape2D" parent="Hotspots/ExamineFrank" index="0"]
shape = SubResource("RectangleShape2D_couloir")

[node name="ExamineSofia" parent="Hotspots" instance=ExtResource("3_hot")]
position = Vector2(1480, 760)
hotspot_type = 2
libelle = "Observer Sofia"
examine_text = "Elle a levé les yeux une seconde. M'a évaluée. Est repartie dans sa lecture. Une seconde lui a suffi pour décider quelque chose."
interaction_offset = Vector2(-80, 50)

[node name="CollisionShape2D" parent="Hotspots/ExamineSofia" index="0"]
shape = SubResource("RectangleShape2D_couloir")

