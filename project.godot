; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="8-mine"
config/description="Jeu narratif type Life is Strange — dialogues branchés, relations, conséquences."
run/main_scene="res://scenes/core/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://b3rj82bj2nput"

[autoload]

Config="*res://scripts/config.gd"
SaveManager="*res://scripts/managers/SaveManager.gd"
GameStateManager="*res://scripts/managers/GameStateManager.gd"
RelationManager="*res://scripts/managers/RelationManager.gd"
CharacterRegistry="*res://scripts/managers/CharacterRegistry.gd"
LocationManager="*res://scripts/managers/LocationManager.gd"
CountdownManager="*res://scripts/managers/CountdownManager.gd"
ExProfileManager="*res://scripts/managers/ExProfileManager.gd"
SurveillanceManager="*res://scripts/managers/SurveillanceManager.gd"
MirrorStatusManager="*res://scripts/managers/MirrorStatusManager.gd"
ReputationManager="*res://scripts/managers/ReputationManager.gd"
SurveillanceHUD="*res://scenes/ui/SurveillanceHUDAutoload.tscn"
GameOverHandler="*res://scripts/managers/GameOverHandler.gd"
Dialogic="*uid://ds2q0uclmolvu"
DialogicBridge="*res://scripts/managers/DialogicBridge.gd"

[debug]

gdscript/warnings/inference_on_variant=1

[dialogic]

directories/dch_directory={
"emma": "res://dialogic/characters/emma.dch",
"margot": "res://dialogic/characters/margot.dch",
"narrator": "res://dialogic/characters/narrator.dch",
"voix_synthetique": "res://dialogic/characters/voix_synthetique.dch"
}
directories/dtl_directory={
"exemple_relation": "res://dialogues/exemple_relation.dtl",
"pro_arrivee": "res://dialogic/timelines/pro_arrivee.dtl"
}
layout/style_directory={}

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="8-mine"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/gut/plugin.cfg", "res://addons/maaacks_game_template/plugin.cfg")

